# Lumen server environment. Copy to `.env` and adjust (real `.env` is gitignored).
# Every value is optional — unset falls back to the dev-friendly default noted.

# Port to listen on. Default 3737 (the test instance conventionally uses 3738).
# PORT=3737

# Initial admin password, stamped onto the auto-created `admin` account at boot
# (and re-applied every start, so this env var is the source of truth — change it
# here to rotate). Set this before a public deploy so the admin account can't be
# claimed by the first visitor. Unset in local dev: admin claims a password on
# first login like any account (the server logs a warning while it's unclaimed).
# ADMIN_PASSWORD=change-me

# New-player registration gate. When set, creating a prospector (or claiming a
# pre-password one) requires an invitation key. This is the HASHED key (a "scrypt:..." string), never the
# plaintext — generate it with `npm run hash-invite-key -- <your-key>` and paste the printed
# INVITE_KEY_HASH=... line here, then share the plaintext key with invitees.
# Unset: registration is open (current behaviour). An admin can also set/rotate
# the key live in-game with `@invite-key` (stored in data/runtime/invite.json,
# which takes precedence over this env default).
# INVITE_KEY_HASH=

# Hide the one-click "Log in as Admin" entry on the login screen (and refuse
# admin logins) when set to 0/false/no/off. Default: shown.
# SHOW_ADMIN_LOGIN=1

# Local-dev convenience: let the admin account log in WITHOUT a password
# (name-only, no set-a-password-on-first-login claim) — handy for a fresh
# checkout or scripted testing where the claim step is pure friction. Set to
# 1/true/yes/on to enable; default OFF. IGNORED whenever ADMIN_PASSWORD is set
# (a real admin password always wins), so it can't weaken a real deployment.
# Only ever affects the admin account. Never set this on a public deploy.
# DEV_ADMIN_NO_PASSWORD=1
