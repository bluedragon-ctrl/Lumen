{
  "name": "lumen",
  "version": "0.6.43",
  "description": "A browser-based MUD of descent, light, and survival.",
  "type": "commonjs",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "validate": "node tools/validate-data.js",
